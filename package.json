{
  "name": "weekendjeweg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test:unit": "node --test tests/foundation.test.mjs && node --import tsx --test tests/*.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:accessibility": "NITRO_PRESET=node_server npm run build && playwright test e2e/accessibility.spec.ts --project=chromium --reporter=line"
  },
  "dependencies": {
    "fast-xml-parser": "5.8.0",
    "lucide-vue-next": "latest",
    "nuxt": "latest",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "4.3.0",
    "tailwindcss": "4.3.0",
    "tsx": "latest",
    "typescript": "latest",
    "vue-tsc": "latest"
  }
}
